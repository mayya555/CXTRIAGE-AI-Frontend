<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CXTRIAGEAI" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorSecondary">#34D399</item>
        <item name="android:statusBarColor">@color/brand_green</item>
        <item name="android:windowAnimationStyle">@style/CustomActivityAnimation</item>
    </style>

    <style name="CustomActivityAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/fade_in_slide_up</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_down_fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in_slide_up</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_down_fade_out</item>
    </style>

    <style name="Theme.CXTRIAGEAI" parent="Base.Theme.CXTRIAGEAI" />

    <style name="OtpEditTextStyle">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/bg_edittext</item>
        <item name="android:gravity">center</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">1</item>
        <item name="android:textColor">#1E293B</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>