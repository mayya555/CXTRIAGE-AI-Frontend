          android:startY="40" 
          android:endY="180" 
          android:type="linear">
        <item android:offset="0.0" android:color="#5A8AE4"/>
        <item android:offset="1.0" android:color="#005A8AE4"/>
      </gradient>
    </aapt:attr>
  </path>
  <!-- Optional stroke line on top -->
  <path
      android:pathData="M0,160 C90,160 120,40 180,40 C240,40 270,120 360,140"
      android:strokeWidth="2"
