<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF"/>
            <size android:width="72dp" android:height="72dp"/>
            <stroke android:width="4dp" android:color="#E0E0E0"/>
        </shape>
    </item>
    <item android:top="8dp" android:bottom="8dp" android:left="8dp" android:right="8dp">
        <shape android:shape="oval">
            <solid android:color="#FF5252"/> <!-- Red for active shutter, or white for standard -->
            <stroke android:width="2dp" android:color="#00000000"/> 
        </shape>
    </item>
</layer-list>
