<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ai_performance_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".AiPerformanceActivity">

    <!-- Header Section -->
    <View
        android:id="@+id/header_bg"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#3B32D1"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="20dp"
        android:src="@drawable/ic_arrow_back_white"
        app:layout_constraintBottom_toBottomOf="@id/tv_header_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_header_title" />

    <TextView
        android:id="@+id/tv_header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="AI Performance Overview"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/header_bg"
        app:layout_constraintStart_toEndOf="@id/iv_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.6" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp">

            <!-- 1. AI Processing Performance Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_performance_card"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_circle_blue_light" android:padding="8dp" android:src="@drawable/ic_performance" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Processing Performance" android:textColor="#0F172A" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Average Inference: 8.2s" android:textColor="#1E293B" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Status: Running (Optimal)" android:textColor="#10B981" android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Rate: 12 images/min" android:textColor="#64748B" android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 2. AI Throughput & Scalability Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_performance_card"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_circle_blue_light" android:padding="8dp" android:src="@drawable/ic_throughput" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Throughput &amp; Scalability" android:textColor="#0F172A" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Total Today: 1,248 X-rays" android:textColor="#1E293B" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="ER: 45% | ICU: 30% | OPD: 25%" android:textColor="#64748B" android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. AI Accuracy & Clinical KPI Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_performance_card"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_circle_blue_light" android:padding="8dp" android:src="@drawable/ic_accuracy" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Accuracy &amp; Clinical KPIs" android:textColor="#0F172A" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                    <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:columnCount="2">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sensitivity: 94.2%" android:textColor="#1E293B" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="24dp" android:text="NPV: 98.4%" android:textColor="#10B981" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="False Neg: 1.2%" android:textColor="#EF4444" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="24dp" android:layout_marginTop="4dp" android:text="AI vs Rad: 91% Match" android:textColor="#3B32D1" android:textSize="14sp" />
                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 4. AI Triage Effectiveness Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_performance_card"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_circle_blue_light" android:padding="8dp" android:src="@drawable/ic_triage_stat" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Triage Effectiveness" android:textColor="#0F172A" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Critical Cases: 142 detected" android:textColor="#EF4444" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Avg Time Saved: 35m / case" android:textColor="#3B32D1" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Turnaround Reduction: 42%" android:textColor="#10B981" android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 5. AI Quality Control Monitoring Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_performance_card"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_circle_blue_light" android:padding="8dp" android:src="@drawable/ic_qc" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Quality Control (QC)" android:textColor="#0F172A" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Poor Quality Flagged: 3.2%" android:textColor="#1E293B" android:textSize="15sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Issues: Motion blur, Underexposure" android:textColor="#64748B" android:textSize="13sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="#FFF1F2" android:paddingHorizontal="8dp" android:paddingVertical="4dp" android:text="WARNING: Repeat image recommended for 2 cases" android:textColor="#E11D48" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 6. AI Transparency & Trust Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_performance_card"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_circle_blue_light" android:padding="8dp" android:src="@drawable/ic_transparency" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Transparency &amp; Trust" android:textColor="#0F172A" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Explainable AI: Saliency Maps Enabled" android:textColor="#3B32D1" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Validation: Clinically Validated - Active" android:textColor="#10B981" android:textSize="13sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Model: Multi-center, Multi-vendor trained" android:textColor="#64748B" android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 7. AI Feedback & Continuos Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_performance_card"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_circle_blue_light" android:padding="8dp" android:src="@drawable/ic_feedback" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Feedback &amp; Validation" android:textColor="#0F172A" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Acceptance Rate: 89% accepted" android:textColor="#1E293B" android:textSize="15sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Model Drift: Nominal (Stable)" android:textColor="#10B981" android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Retraining: Not required at this time" android:textColor="#64748B" android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 8. AI System Health Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_performance_card"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_circle_blue_light" android:padding="8dp" android:src="@drawable/ic_system_health" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="System Health" android:textColor="#0F172A" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Uptime: 99.98%" android:textColor="#10B981" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Model version: v2.4.1" android:textColor="#64748B" android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Last Update: 2023-11-20 04:00" android:textColor="#64748B" android:textSize="12sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="• Fail-safe manual workflow: ACTIVE" android:textColor="#3B32D1" android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Chatbot FAB Trigger -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_chatbot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@drawable/ic_chatbot"
        app:backgroundTint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/brand_blue" />

    <!-- Chatbot Panel Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/chat_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#990F172A"
        android:visibility="gone"
        tools:visibility="visible">

        <androidx.cardview.widget.CardView
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:layout_marginVertical="24dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white">

                <!-- Chat Header -->
                <LinearLayout
                    android:id="@+id/chat_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F8FAFC"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_chatbot" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Support Assistant"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Online • Clinical Support"
                            android:textColor="#10B981"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/iv_close_chat"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_reject_x"
                        app:tint="#64748B" />
                </LinearLayout>

                <!-- Disclaimer -->
                <TextView
                    android:id="@+id/tv_disclaimer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFBEB"
                    android:padding="8dp"
                    android:text="Disclaimer: This AI assistant is for operational support only and does not provide medical diagnosis."
                    android:textColor="#92400E"
                    android:textSize="9sp"
                    android:textStyle="italic"
                    app:layout_constraintTop_toBottomOf="@id/chat_header" />

                <!-- Chat Messages Scroll -->
                <ScrollView
                    android:id="@+id/scroll_messages"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:padding="16dp"
                    app:layout_constraintBottom_toTopOf="@id/quick_actions"
                    app:layout_constraintTop_toBottomOf="@id/tv_disclaimer">

                    <LinearLayout
                        android:id="@+id/chat_messages_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Bot Message -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="40dp"
                            android:background="@drawable/bg_chat_bubble_bot"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hello! I am your AI assistant. How can I help you today? You can ask me to explain metrics or troubleshoot flags."
                                android:textColor="#334155"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </ScrollView>

                <!-- Quick Actions -->
                <HorizontalScrollView
                    android:id="@+id/quick_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="12dp"
                    android:scrollbars="none"
                    app:layout_constraintBottom_toTopOf="@id/input_area">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btn_explain_metric"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_outlined_button_rounded"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="Explain this metric"
                            android:textColor="@color/brand_blue"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/btn_why_flagged"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_outlined_button_rounded"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="Why is this flagged?"
                            android:textColor="@color/brand_blue"
                            android:textSize="11sp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Input Area -->
                <LinearLayout
                    android:id="@+id/input_area"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F8FAFC"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <EditText
                        android:id="@+id/et_chat_input"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_login_input"
                        android:hint="Type a message..."
                        android:inputType="textShortMessage"
                        android:paddingHorizontal="16dp"
                        android:textSize="13sp" />

                    <ImageView
                        android:id="@+id/iv_send_chat"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:padding="4dp"
                        android:src="@drawable/ic_send_blue" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
