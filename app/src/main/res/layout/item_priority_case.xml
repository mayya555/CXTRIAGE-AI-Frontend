<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp"
    app:cardBackgroundColor="#064E3B"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="0dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/card_thumbnail"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_thumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_scan_placeholder"
                android:visibility="invisible"
                android:padding="0dp"/>

            <ImageView
                android:id="@+id/iv_alert_overlay"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="top|end"
                android:layout_margin="4dp"
                android:src="@drawable/ic_alert_triangle"
                android:padding="4dp"
                android:background="@drawable/bg_circle_red"
                app:tint="@color/white" />

        </androidx.cardview.widget.CardView>

        <!-- Patient Name -->
        <TextView
            android:id="@+id/tv_patient_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="John Doe"
            android:textColor="#022C22"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/card_thumbnail"
            app:layout_constraintTop_toTopOf="@id/card_thumbnail"
            app:layout_constraintEnd_toStartOf="@id/tv_wait_time" />

        <!-- Wait Time -->
        <TextView
            android:id="@+id/tv_wait_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12m"
            android:textColor="#10B981"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_patient_name" />

        <!-- Priority Badge & Condition -->
        <LinearLayout
            android:id="@+id/layout_details"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/card_thumbnail"
            app:layout_constraintTop_toBottomOf="@id/tv_patient_name">

            <TextView
                android:id="@+id/tv_priority_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_light_red"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="CRITICAL"
                android:textColor="#059669"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_condition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Pneumothorax"
                android:textColor="#065F46"
                android:textSize="14sp"
                android:ellipsize="end"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Priority Bar -->
        <View
            android:id="@+id/priority_line"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_marginTop="16dp"
            android:background="#059669"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_thumbnail" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
