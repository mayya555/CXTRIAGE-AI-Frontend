<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_role_card"
    android:elevation="4dp"
    android:padding="20dp">

    <ImageView
        android:id="@+id/iv_hospital_icon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_circle_blue_light"
        android:padding="14dp"
        android:src="@drawable/ic_bolt"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/brand_blue" />

    <TextView
        android:id="@+id/tv_hospital_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="12dp"
        android:text="Hospital Name"
        android:textColor="#1E293B"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tv_hospital_location"
        app:layout_constraintEnd_toStartOf="@id/iv_chevron"
        app:layout_constraintStart_toEndOf="@id/iv_hospital_icon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tv_hospital_location"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Location Details"
        android:textColor="#64748B"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/tv_hospital_name"
        app:layout_constraintStart_toStartOf="@id/tv_hospital_name"
        app:layout_constraintTop_toBottomOf="@id/tv_hospital_name" />

    <ImageView
        android:id="@+id/iv_chevron"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_chevron_right"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#CBD5E1" />

</androidx.constraintlayout.widget.ConstraintLayout>
