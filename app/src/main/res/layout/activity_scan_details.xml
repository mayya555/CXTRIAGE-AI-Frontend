<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Header Section -->
    <View
        android:id="@+id/header_bg"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#10B981"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Scan Details"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/iv_back"
        app:layout_constraintStart_toEndOf="@id/iv_back"
        app:layout_constraintTop_toTopOf="@id/iv_back" />

    <ImageView
        android:id="@+id/iv_more"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="20dp"
        android:src="@drawable/ic_more_vert"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="@id/tv_header_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_header_title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_bg">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <!-- Scan ID Badge -->
            <View
                android:id="@+id/v_scan_id_bg"
                android:layout_width="120dp"
                android:layout_height="32dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_badge_light_green"
                android:backgroundTint="#F0FDF4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_scan_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCN-8472"
                android:textColor="#10B981"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/v_scan_id_bg"
                app:layout_constraintEnd_toEndOf="@id/v_scan_id_bg"
                app:layout_constraintStart_toStartOf="@id/v_scan_id_bg"
                app:layout_constraintTop_toTopOf="@id/v_scan_id_bg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Scan Identification Number"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/v_scan_id_bg" />

            <!-- Patient Detail Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_patient_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:layout_constraintTop_toBottomOf="@id/tv_scan_id"
                app:layout_constraintBottom_toTopOf="@id/tv_timeline_label">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <View
                        android:id="@+id/iv_avatar_bg"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_circle_green_light"
                        android:backgroundTint="#F0FDF4"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_person"
                        app:tint="#10B981"
                        app:layout_constraintBottom_toBottomOf="@id/iv_avatar_bg"
                        app:layout_constraintEnd_toEndOf="@id/iv_avatar_bg"
                        app:layout_constraintStart_toStartOf="@id/iv_avatar_bg"
                        app:layout_constraintTop_toTopOf="@id/iv_avatar_bg" />

                    <TextView
                        android:id="@+id/tv_patient_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Sarah Wilson"
                        android:textColor="#0F172A"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iv_avatar_bg"
                        app:layout_constraintTop_toTopOf="@id/iv_avatar_bg" />

                    <TextView
                        android:id="@+id/tv_mrn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MRN-4521"
                        android:textColor="#94A3B8"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="@id/tv_patient_name"
                        app:layout_constraintTop_toBottomOf="@id/tv_patient_name" />

                    <!-- Grid Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date of Birth" android:textColor="#94A3B8" android:textSize="12sp" />
                            <TextView android:id="@+id/tv_dob" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mar 15, 1985" android:textColor="#0F172A" android:textStyle="bold" android:layout_marginTop="4dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Scan Date" android:textColor="#94A3B8" android:textSize="12sp" android:layout_marginTop="16dp"/>
                            <TextView android:id="@+id/tv_scan_details_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Today, 11:20 AM" android:textColor="#0F172A" android:textStyle="bold" android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gender" android:textColor="#94A3B8" android:textSize="12sp" />
                            <TextView android:id="@+id/tv_gender" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Female" android:textColor="#0F172A" android:textStyle="bold" android:layout_marginTop="4dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Technician" android:textColor="#94A3B8" android:textSize="12sp" android:layout_marginTop="16dp"/>
                            <TextView android:id="@+id/tv_technician" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="James Chen" android:textColor="#0F172A" android:textStyle="bold" android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_timeline_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="PROCESSING TIMELINE"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cv_patient_details" />

            <!-- Timeline -->
            <LinearLayout
                android:id="@+id/v_timeline_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/tv_timeline_label">

                <!-- Step 1 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <View android:id="@+id/v_line1" android:layout_width="2dp" android:layout_height="60dp" android:background="#E2E8F0" android:layout_marginStart="16dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>
                    <ImageView android:id="@+id/iv_step1" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_check_circle_green" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="X-Ray Captured" android:textColor="#0F172A" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/iv_step1" app:layout_constraintTop_toTopOf="@id/iv_step1" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Today at 11:20 AM" android:textColor="#94A3B8" android:textSize="12sp" app:layout_constraintStart_toEndOf="@id/iv_step1" app:layout_constraintTop_toBottomOf="@id/iv_step1" android:layout_marginTop="2dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Step 2 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp">
                    <View android:id="@+id/v_line2" android:layout_width="2dp" android:layout_height="60dp" android:background="#E2E8F0" android:layout_marginStart="16dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>
                    <ImageView android:id="@+id/iv_step2" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_check_circle_green" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Quality Validated" android:textColor="#0F172A" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/iv_step2" app:layout_constraintTop_toTopOf="@id/iv_step2" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Today at 11:21 AM" android:textColor="#94A3B8" android:textSize="12sp" app:layout_constraintStart_toEndOf="@id/iv_step2" app:layout_constraintTop_toBottomOf="@id/iv_step2" android:layout_marginTop="2dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Step 3 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp">
                    <View android:id="@+id/v_line3" android:layout_width="2dp" android:layout_height="100dp" android:background="#E2E8F0" android:layout_marginStart="16dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>
                    <ImageView android:id="@+id/iv_step3" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_check_circle_green" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Uploaded to Server" android:textColor="#0F172A" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/iv_step3" app:layout_constraintTop_toTopOf="@id/iv_step3" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Today at 11:22 AM" android:textColor="#94A3B8" android:textSize="12sp" app:layout_constraintStart_toEndOf="@id/iv_step3" app:layout_constraintTop_toBottomOf="@id/iv_step3" android:layout_marginTop="2dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Step 4 (In Progress) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp">
                    <View android:id="@+id/v_line4" android:layout_width="2dp" android:layout_height="80dp" android:background="#E2E8F0" android:layout_marginStart="16dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>
                    <ImageView android:id="@+id/iv_step4" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/bg_dot_yellow" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
                    <TextView android:id="@+id/tv_step4_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="AI Analysis in Progress" android:textColor="#0F172A" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/iv_step4" app:layout_constraintTop_toTopOf="@id/iv_step4" />
                    <TextView android:id="@+id/tv_step4_subtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Estimated completion: 2-3 minutes" android:textColor="#94A3B8" android:textSize="12sp" app:layout_constraintStart_toEndOf="@id/iv_step4" app:layout_constraintTop_toBottomOf="@id/tv_step4_title" android:layout_marginTop="2dp" />
                    <ProgressBar android:id="@+id/pb_analysis" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="4dp" android:layout_marginStart="16dp" android:layout_marginTop="12dp" android:progress="60" android:progressTint="#FBBF24" android:backgroundTint="#F1F5F9" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toEndOf="@id/iv_step4" app:layout_constraintTop_toBottomOf="@id/tv_step4_subtitle" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Step 5 (Pending/Sent) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp">
                    <ImageView android:id="@+id/iv_step5" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_clock_status" app:tint="#CBD5E1" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
                    <TextView android:id="@+id/tv_step5_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Doctor Review" android:textColor="#94A3B8" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/iv_step5" app:layout_constraintTop_toTopOf="@id/iv_step5" />
                    <TextView android:id="@+id/tv_step5_subtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Pending AI completion" android:textColor="#94A3B8" android:textSize="12sp" app:layout_constraintStart_toEndOf="@id/iv_step5" app:layout_constraintTop_toBottomOf="@id/tv_step5_title" android:layout_marginTop="2dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_scan_info_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="SCAN INFORMATION"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/v_timeline_container" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/tv_scan_info_label">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="View Type" android:textColor="#94A3B8" android:textSize="14sp" />
                        <TextView android:id="@+id/tv_view_type" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PA Chest" android:textColor="#0F172A" android:textStyle="bold" android:textSize="14sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginVertical="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Orientation" android:textColor="#94A3B8" android:textSize="14sp" />
                        <TextView android:id="@+id/tv_orientation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Anterior" android:textColor="#0F172A" android:textStyle="bold" android:textSize="14sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginVertical="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Study ID" android:textColor="#94A3B8" android:textSize="14sp" />
                        <TextView android:id="@+id/tv_study_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ST-82941" android:textColor="#0F172A" android:textStyle="bold" android:textSize="14sp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
